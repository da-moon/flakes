+    def _schedule_settlement_backoff(self, slug: str, *, failed: bool) -> None:
+        state = self._settlement_backoff.get(slug)
+        if state is None:
+            state = PriceBackoff()
+            self._settlement_backoff[slug] = state
+        base_delay = max(float(self.cfg.position_sync_interval_sec) * 4.0, 60.0)
+        if failed:
+            state.failures += 1
+            delay = min(base_delay * (2 ** max(0, state.failures - 1)), self.cfg.max_backoff_sec)
+        else:
+            state.failures = 0
+            delay = base_delay
+        state.next_check_monotonic = asyncio.get_running_loop().time() + delay
+
