+        payout_per_share = 1.0 if winner_label.lower() == position.outcome.lower() else 0.0
+        expected_received = float(position.size) * payout_per_share
+        settled_shares = float(position.size)
+        received_usd = expected_received
+
+        settle_market = getattr(self.exchange, "settle_market", None)
+        if settle_market is not None:
+            try:
+                settlement = await asyncio.wait_for(
+                    _run_blocking(
+                        self.background_executor,
+                        settle_market,
+                        position.asset,
+                        payout_per_share,
+                    ),
+                    timeout=20.0,
+                )
+                if isinstance(settlement, dict):
+                    settled_shares = _safe_float(settlement.get("shares"), settled_shares)
+                    received_usd = _safe_float(settlement.get("received_usd"), received_usd)
+            except Exception as exc:
+                logger.warning("nothing_happens_paper_settlement_failed slug=%s err=%s", position.slug, exc)
+                self._schedule_settlement_backoff(position.slug, failed=True)
+                return
+        elif self._cash_balance is not None and received_usd > 0.0:
+            self._cash_balance = float(self._cash_balance) + received_usd
+
+        pnl_usd = received_usd - float(position.initial_value)
+        now_us = int(time.time() * 1_000_000)
