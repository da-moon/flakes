+    async def _settle_resolved_local_positions(
+        self,
+        positions_by_slug: dict[str, PositionSnapshot],
+        now_ts: float,
+    ) -> dict[str, PositionSnapshot]:
+        if not self._local_positions:
+            return positions_by_slug
+
+        loop_now = asyncio.get_running_loop().time()
+        due_positions: list[LocalPosition] = []
+        for slug, position in list(self._local_positions.items()):
+            if position.end_ts > now_ts:
+                continue
+            backoff = self._settlement_backoff.get(slug)
+            if backoff is not None and loop_now < backoff.next_check_monotonic:
+                continue
+            due_positions.append(position)
+            if len(due_positions) >= PAPER_SETTLEMENT_BATCH_LIMIT:
+                break
+
+        for position in due_positions:
+            try:
+                winner = await _check_gamma_resolution(position.slug)
+            except Exception as exc:
+                logger.warning("nothing_happens_paper_resolution_failed slug=%s err=%s", position.slug, exc)
+                self._schedule_settlement_backoff(position.slug, failed=True)
+                continue
+
+            if winner is None:
+                self._schedule_settlement_backoff(position.slug, failed=False)
+                continue
+
+            await self._settle_local_position(
+                position=position,
+                winner=winner,
+                positions_by_slug=positions_by_slug,
+            )
+
+        return positions_by_slug
+
+    async def _settle_local_position(
